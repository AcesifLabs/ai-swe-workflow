{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequentialthinking": {
      "type": "remote",
      "url": "https://remote.mcpservers.org/sequentialthinking/mcp"
    }
  },
  "plugin": [
    "opencode-antigravity-auth@latest"
  ],
  "instructions": [
    "/home/asif/.config/opencode/instructions/plan.md",
    "/home/asif/.config/opencode/instructions/code-review.md"
  ],
  "mode": {
    "plan": {
      "prompt": "{file:/home/asif/.config/opencode/instructions/plan.md}",
      "tools": {
        "write": false,
        "edit": false,
        "bash": true
      }
    },
    "review": {
      "prompt": "{file:/home/asif/.config/opencode/instructions/code-review.md}",
      "tools": {
        "read": true,
        "grep": true,
        "write": false
      }
    }
  },
  "provider": {
    "google": {
      "models": {
        "antigravity-claude-opus-4-5-thinking": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192
              }
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768
              }
            }
          }
        },
        "antigravity-claude-sonnet-4-5": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
